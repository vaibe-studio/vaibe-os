# vaibe-os: переменные окружения
# Скопируйте в .env и подставьте свои значения. Файл .env не коммитить.

# ============================================
# YouTrack (опционально)
# ============================================
# URL инстанса YouTrack
YOUTRACK_URL=https://your-youtrack.example

# Постоянный токен: YouTrack → Profile → Account Security → New token
YOUTRACK_TOKEN=perm:your-token-here

# Короткое имя проекта по умолчанию для создания задач
YOUTRACK_PROJECT_ID=PROJECT

# ============================================
# Cursor: статистика использования (опционально)
# ============================================
# Cookie для доступа к API Cursor:
#   1. Открыть cursor.com в браузере, войти
#   2. DevTools (F12) → Application → Cookies → cursor.com
#   3. Скопировать значение WorkosCursorSessionToken
CURSOR_AUTH_COOKIE=your-cookie-value-here

# ============================================
# Прочие интеграции (по необходимости)
# ============================================
# Пример: транскрипция аудио/видео
# ASSEMBLYAI_API_KEY=your-api-key-here
