# vAIbe-OS Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# YouTrack Integration (optional)
# ============================================

# YouTrack instance URL
YOUTRACK_URL=https://your-youtrack-instance.example.com

# YouTrack permanent token
# Get it from: YouTrack → Profile → Account Security → New token
YOUTRACK_TOKEN=perm-your-token-here

# Default project short name for creating issues
YOUTRACK_PROJECT_ID=PROJECT

# ============================================
# YouTrack — Additional profile (optional)
# ============================================
# For projects on a different YouTrack instance, use profile-based config:
# YOUTRACK_{PROFILE}_URL=https://another-youtrack.example.com
# YOUTRACK_{PROFILE}_TOKEN=perm-your-token-here
# YOUTRACK_{PROFILE}_PROJECT_ID=PRJ

# ============================================
# AssemblyAI Transcription (optional)
# ============================================

# AssemblyAI API key for video/audio transcription
# Get it from: https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=your-api-key-here

# HuggingFace token for pyannote.audio model access (speaker diarization)
# Get your token at: https://huggingface.co/settings/tokens
# Accept model terms at: https://huggingface.co/pyannote/speaker-diarization-community-1
HUGGINGFACE_TOKEN=hf_your-token-here
